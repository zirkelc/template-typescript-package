{
  "name": "PACKAGE",
  "version": "1.0.0",
  "description": "DESCRIPTION",
  "keywords": [],
  "license": "LICENSE",
  "author": "AUTHOR",
  "repository": {
    "type": "git",
    "url": "https://github.com/USERNAME/REPO"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
