  "name": "<PACKAGE>",
  "version": "1.0.0",
  "description": "<DESCRIPTION>",
  "keywords": [],
  "license": "<LICENSE>",
  "author": "<AUTHOR>",
  "repository": {
    "type": "git",
    "url": "https://github.com/<USERNAME>/<REPO>"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
